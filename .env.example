# ─── Obligatorios (la app no arranca sin ellos) ─────────────────────────────
# Conexión a PostgreSQL (ejemplo con usuario/pass; también sirve connection string de Supabase, Neon, etc.)
DATABASE_URL="postgresql://usuario:password@localhost:5432/hotel_costa"

# NextAuth: secreto para firmar JWT (mínimo 32 caracteres). Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-muy-largo-de-al-menos-32-caracteres"

# ─── Opcionales ───────────────────────────────────────────────────────────
# URL pública de la app (útil detrás de Nginx/proxy o en producción)
# NEXTAUTH_URL="https://tu-dominio.com"

# ─── MotoPress (solo si vas a sincronizar reservas desde WordPress/MotoPress) ─
# MOTOPRESS_URL="https://tu-sitio-wordpress.com"
# MOTOPRESS_CONSUMER_KEY="ck_xxxx"
# MOTOPRESS_CONSUMER_SECRET="cs_xxxx"
# MOTOPRESS_SYNC_DAYS=90
# MOTOPRESS_ESTABLISHMENT_ID="cuid-del-establishment"

# ─── API de sincronización MotoPress ───────────────────────────────────────
# Secreto para autorizar POST/GET a /api/sync/motopress (Bearer token o ?secret=)
# SYNC_SECRET="un-secreto-para-proteger-la-ruta-de-sync"

# ─── Desarrollo (opcional) ─────────────────────────────────────────────────
# Saltar validación de env al iniciar (no usar en producción)
# SKIP_ENV_VALIDATION=1
